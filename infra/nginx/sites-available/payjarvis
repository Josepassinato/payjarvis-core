# PayJarvis — Nginx Production Config (SSL)
# Domínio: payjarvis.com

server {
    listen 443 ssl;
    server_name payjarvis.com www.payjarvis.com;

    ssl_certificate /etc/letsencrypt/live/payjarvis.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/payjarvis.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # ─── Security Headers ───
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ─── API Proxy ───
    location /api/ {
        proxy_pass http://localhost:3001/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # ─── SSE (Approvals) ───
    location /api/approvals/stream {
        proxy_pass http://localhost:3001/approvals/stream;
        proxy_http_version 1.1;
        proxy_set_header Connection '';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
    }

    # ─── Public Endpoints ───
    location /v1/ {
        proxy_pass http://localhost:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /.well-known/jwks.json {
        proxy_pass http://localhost:3001;
        proxy_set_header Host $host;
    }

    location /health {
        proxy_pass http://localhost:3001;
        proxy_set_header Host $host;
    }

    # ─── Web Dashboard (default) ───
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

# ─── HTTP → HTTPS redirect ───
server {
    listen 80;
    server_name payjarvis.com www.payjarvis.com;
    return 301 https://$host$request_uri;
}
