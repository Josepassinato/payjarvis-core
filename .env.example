# ─── Database (Supabase) ───
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─── Cache (Upstash Redis) ───
REDIS_URL="rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379"

# ─── Auth (Clerk) ───
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# ─── Payments (Stripe) ───
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── BDIT Keys (RS256) ───
# Generate with: npx ts-node packages/bdit/src/generate-keys.ts
PAYJARVIS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
PAYJARVIS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PAYJARVIS_KEY_ID="payjarvis-key-2026-03"

# ─── Ports ───
API_PORT=3001
RULES_ENGINE_PORT=3002
BROWSER_AGENT_PORT=3003

# ─── URLs ───
RULES_ENGINE_URL="http://localhost:3002"
PAYJARVIS_API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# ─── Browser Agent (OpenClaw CDP) ───
OPENCLAW_CDP_PORT=18800
JWKS_PUBLIC_URL="https://api.payjarvis.com/.well-known/jwks.json"

# ─── Email (Resend) ───
RESEND_API_KEY="re_..."

# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN="<your-bot-token-from-@BotFather>"
TELEGRAM_WEBHOOK_SECRET="<random-secret-for-webhook-validation>"

# ─── Environment ───
NODE_ENV="development"
