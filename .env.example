# ─────────────────────────────────────────────────────
# PayJarvis — Environment Variables
# Copy this file: cp .env.example .env
# Fill in your values and NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# ─── Database ───
# Local: postgresql://payjarvis:payjarvis@localhost:5432/payjarvis
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true
DATABASE_URL="postgresql://payjarvis:payjarvis@localhost:5432/payjarvis"
# Direct connection (bypasses pgbouncer, used for migrations)
DIRECT_URL="postgresql://payjarvis:payjarvis@localhost:5432/payjarvis"

# ─── Cache (Redis) ───
# Leave empty to use in-memory fallback (fine for dev)
REDIS_URL=""

# ─── Auth (Clerk) ───
# Get keys at https://dashboard.clerk.com → API Keys
# Leave empty or set to "sk_test_placeholder" for dev-mode auth bypass
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"
NEXT_PUBLIC_CLERK_PROXY_URL=""

# ─── BDIT Keys (RS256) ───
# Generate with: npx ts-node packages/bdit/src/generate-keys.ts
# Or: openssl genrsa 2048 > private.pem && openssl rsa -in private.pem -pubout > public.pem
# Paste contents with literal \n for newlines
PAYJARVIS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
PAYJARVIS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
# Key ID for JWKS rotation — change when rotating keys
PAYJARVIS_KEY_ID="payjarvis-key-001"
# Previous key (set during key rotation — remove after grace period)
# PAYJARVIS_PUBLIC_KEY_PREV=""
# PAYJARVIS_KEY_ID_PREV=""

# ─── Payments (Stripe) ───
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Payments (PayPal — optional) ───
# Get credentials at https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# "sandbox" or "live"
PAYPAL_ENVIRONMENT="sandbox"

# ─── Payment Vault ───
# AES-256 encryption key for storing payment credentials
# Generate with: openssl rand -hex 32
PAYMENT_VAULT_KEY=""

# ─── AI (Gemini) ───
# Used for intelligent transaction categorization
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── AI (Anthropic — optional) ───
# Used for KYC document OCR via Claude Vision
# Get key at https://console.anthropic.com/settings/keys
# If not set, OCR is unavailable and users fill fields manually
ANTHROPIC_API_KEY=""

# ─── Notifications (Telegram) ───
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=""
# Random secret for webhook validation — generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=""

# ─── Notifications (Email via Resend) ───
# Get key at https://resend.com/api-keys
RESEND_API_KEY=""

# ─── Supabase (optional, alternative to local PostgreSQL) ───
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Service Ports ───
API_PORT=3001
RULES_ENGINE_PORT=3002
BROWSER_AGENT_PORT=3003
OPENCLAW_CDP_PORT=18800

# ─── Service URLs ───
RULES_ENGINE_URL="http://localhost:3002"
PAYJARVIS_API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
# JWKS endpoint for BDIT token verification
JWKS_PUBLIC_URL="http://localhost:3001/.well-known/jwks.json"

# ─── Verify SDK Rate Limiting ───
# Max requests per window for /v1/verify endpoint
VERIFY_RATE_LIMIT_MAX=100
# Window size in milliseconds (default: 60000 = 1 minute)
VERIFY_RATE_LIMIT_WINDOW_MS=60000

# ─── Commerce APIs ───
# Amadeus — flights and hotels (https://developers.amadeus.com)
AMADEUS_CLIENT_ID=""
AMADEUS_CLIENT_SECRET=""
# "test" or "production"
AMADEUS_ENV="test"

# Yelp Fusion — restaurants (https://fusion.yelp.com)
YELP_API_KEY=""

# OpenTable — restaurant reservations (partner API)
OPENTABLE_CLIENT_ID=""

# Ticketmaster — events (https://developer.ticketmaster.com)
TICKETMASTER_API_KEY=""

# Uber — transport (https://developer.uber.com)
UBER_CLIENT_ID=""
UBER_CLIENT_SECRET=""

# iFood — food delivery BR/LATAM (https://developer.ifood.com.br)
# OAuth2 Client Credentials — API voltada para merchants/POS
# Consumer orders via Layer 4 (Browserbase)
IFOOD_CLIENT_ID=""
IFOOD_CLIENT_SECRET=""
IFOOD_MERCHANT_ID=""

# ─── Retail APIs ───
# Walmart Open API (https://developer.walmart.com)
WALMART_CONSUMER_ID=""
WALMART_PRIVATE_KEY=""
WALMART_CHANNEL_TYPE=""
WALMART_AFFILIATE_ID=""

# Walgreens API (https://developer.walgreens.com)
WALGREENS_APP_ID=""
WALGREENS_APP_KEY=""

# CVS (browser-agent assisted)
CVS_API_KEY=""

# Target (https://developer.target.com or CJ Affiliate)
TARGET_API_KEY=""
TARGET_AFFILIATE_ID=""

# Macy's (CJ Affiliate)
MACYS_AFFILIATE_ID=""
MACYS_API_KEY=""

# ─── Transit APIs ───
# Amtrak (https://amtrak.com/developer)
AMTRAK_API_KEY=""

# FlixBus/Greyhound (https://flixbus.com/affiliate)
FLIXBUS_API_KEY=""

# ─── Car Rental ───
ENTERPRISE_API_KEY=""

# ─── Browserbase (Cloud Browser) ───
# Get keys at https://browserbase.com/settings
BROWSERBASE_API_KEY=""
BROWSERBASE_PROJECT_ID=""
# Internal URL for API → browser-agent communication
BROWSER_AGENT_URL="http://localhost:3003"

# ─── Environment ───
NODE_ENV="development"

# ─── BDIT Environment ───
# Override to separate BDIT token namespaces (dev/staging/prod)
# If not set, defaults to NODE_ENV. In production, issuer is "payjarvis".
# In other envs, issuer becomes "payjarvis-<env>" (e.g. "payjarvis-development").
# BDIT_ENV="development"
