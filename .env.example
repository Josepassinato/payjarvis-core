# ─────────────────────────────────────────────────────
# PayJarvis — Environment Variables
# Copy this file: cp .env.example .env
# Fill in your values and NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# ─── Database ───
# Local: postgresql://payjarvis:payjarvis@localhost:5432/payjarvis
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true
DATABASE_URL="postgresql://payjarvis:payjarvis@localhost:5432/payjarvis"
# Direct connection (bypasses pgbouncer, used for migrations)
DIRECT_URL="postgresql://payjarvis:payjarvis@localhost:5432/payjarvis"

# ─── Cache (Redis) ───
# Leave empty to use in-memory fallback (fine for dev)
REDIS_URL=""

# ─── Auth (Clerk) ───
# Get keys at https://dashboard.clerk.com → API Keys
# Leave empty or set to "sk_test_placeholder" for dev-mode auth bypass
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"
NEXT_PUBLIC_CLERK_PROXY_URL=""

# ─── BDIT Keys (RS256) ───
# Generate with: npx ts-node packages/bdit/src/generate-keys.ts
# Or: openssl genrsa 2048 > private.pem && openssl rsa -in private.pem -pubout > public.pem
# Paste contents with literal \n for newlines
PAYJARVIS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
PAYJARVIS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
# Key ID for JWKS rotation — change when rotating keys
PAYJARVIS_KEY_ID="payjarvis-key-001"

# ─── Payments (Stripe) ───
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Payment Vault ───
# AES-256 encryption key for storing payment credentials
# Generate with: openssl rand -hex 32
PAYMENT_VAULT_KEY=""

# ─── AI (Gemini) ───
# Used for intelligent transaction categorization
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── Notifications (Telegram) ───
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=""
# Random secret for webhook validation — generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=""

# ─── Notifications (Email via Resend) ───
# Get key at https://resend.com/api-keys
RESEND_API_KEY=""

# ─── Supabase (optional, alternative to local PostgreSQL) ───
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Service Ports ───
API_PORT=3001
RULES_ENGINE_PORT=3002
BROWSER_AGENT_PORT=3003
OPENCLAW_CDP_PORT=18800

# ─── Service URLs ───
RULES_ENGINE_URL="http://localhost:3002"
PAYJARVIS_API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
# JWKS endpoint for BDIT token verification
JWKS_PUBLIC_URL="http://localhost:3001/.well-known/jwks.json"

# ─── Environment ───
NODE_ENV="development"
