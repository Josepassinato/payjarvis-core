// ─── Butler Protocol 🎩 ───

model ButlerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  fullName    String?  // encrypted via encryptPII
  email       String?  // encrypted
  address     String?  // encrypted (JSON: street, city, state, zip, country)
  phone       String?  // encrypted
  dateOfBirth String?  // encrypted
  ssn         String?  // encrypted (optional)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  credentials ButlerCredential[]

  @@map("butler_profiles")
}

model ButlerCredential {
  id                String    @id @default(cuid())
  userId            String
  serviceName       String    // "Best Buy", "Amazon", etc.
  serviceUrl        String    // "bestbuy.com"
  login             String    // encrypted
  encryptedPassword String    // encrypted
  notes             String?
  createdAt         DateTime  @default(now())
  lastUsed          DateTime?

  profile ButlerProfile @relation(fields: [userId], references: [userId])

  @@unique([userId, serviceName])
  @@index([userId])
  @@map("butler_credentials")
}

model ButlerAuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "setup_profile", "create_account", "fill_form", "update_profile"
  service   String?  // "bestbuy.com"
  status    String   // "success", "failed", "pending_confirmation"
  details   String?  // JSON
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("butler_audit_logs")
}

// ─── Butler — Connected Google/Microsoft Accounts ───

model ButlerConnectedAccount {
  id            String   @id @default(cuid())
  userId        String
  provider      String   // "google" | "microsoft"
  email         String   // user's email on this provider
  accessToken   String   // encrypted
  refreshToken  String   // encrypted
  tokenExpiry   DateTime?
  scopes        String[] // ["gmail.readonly", "calendar.readonly", ...]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("butler_connected_accounts")
}

// ─── Scheduled Tasks (User-created recurring jobs) ───

model ScheduledTask {
  id          String    @id @default(cuid())
  userId      String
  description String    // "Buscar notícias de tecnologia"
  action      String    // "search_news" | "search_products" | "check_weather" | "web_search" | "custom_message"
  actionData  Json?     // { query: "technology news", tool: "search_news" }
  schedule    String    // Cron expression: "0 8 * * *"
  timezone    String    @default("America/New_York")
  channel     String    // "whatsapp" | "telegram"
  channelId   String    // whatsapp:+19546432431 or telegram chatId
  language    String    @default("pt")
  active      Boolean   @default(true)
  lastRun     DateTime?
  nextRun     DateTime?
  runCount    Int       @default(0)
  maxRuns     Int?      // null = infinite
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs ScheduledTaskLog[]

  @@index([active, nextRun])
  @@index([userId])
  @@map("scheduled_tasks")
}

model ScheduledTaskLog {
  id        String   @id @default(cuid())
  taskId    String
  status    String   // "success" | "failed" | "skipped"
  result    String?  @db.Text
  error     String?
  duration  Int?     // ms
  createdAt DateTime @default(now())

  task ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
  @@map("scheduled_task_logs")
}

// ─── Inner Circle — Specialist Referral Network ───

model InnerCircleSpecialist {
  id                String   @id @default(cuid())
  name              String   // "Jessica Passinato"
  slug              String   @unique // "jessica-passinato"
  expertise         String   // "Consultoria de Imagem, Coloração Pessoal"
  bio               String   // Short bio for Jarvis to use
  credentials       String   // "15+ anos de experiência"
  instagram         String?  // "@jessicapassinato"
  website           String?  // "jessicapassinato.com"
  contactLink       String?  // Direct premium booking link
  freeServices      String   // JSON array of free AI-powered services
  premiumServices   String   // JSON array of paid human services
  triggerKeywords   String   // JSON array of detection keywords
  triggerContexts   String   // JSON array of intent contexts
  aiKnowledgePrompt String   @db.Text // Expert knowledge for AI consultations
  introMessage      String   @db.Text // Template for friend-style intro
  maxFreePerUser    Int      @default(3)
  revenueSharePct   Float    @default(15)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  interactions InnerCircleInteraction[]

  @@map("inner_circle_specialists")
}

model InnerCircleInteraction {
  id           String   @id @default(cuid())
  userId       String
  specialistId String
  type         String   // "free_consultation", "premium_referral", "intro_shown", "declined"
  context      String?  // What the user was doing
  converted    Boolean  @default(false)
  revenue      Float?
  createdAt    DateTime @default(now())

  specialist InnerCircleSpecialist @relation(fields: [specialistId], references: [id])

  @@index([userId, specialistId])
  @@index([userId, createdAt])
  @@map("inner_circle_interactions")
}

