// ─── Zero-Knowledge Vault ───

model UserZkVault {
  id        String   @id @default(cuid())
  userId    String   @unique
  salt      String   // PBKDF2 salt (not secret, stored as hex)
  pinHash   String   // Hash of PIN for verification
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_zk_vaults")
}

model SecureItem {
  id            String   @id @default(cuid())
  userId        String
  itemType      String   // "card", "amazon_credentials", "document", "password"
  label         String   // "Visa ending 4242", "Amazon account", etc.
  encryptedData String   // Ciphertext (base64)
  iv            String   // Initialization vector (base64)
  authTag       String   // GCM authentication tag (base64)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, itemType])
  @@map("secure_items")
}

// ─── Voice Calls ───

model VoiceCall {
  id           String   @id
  userId       String
  callSid      String   @unique
  to           String
  from         String
  businessName String?
  objective    String
  status       String   @default("initiated") // initiated, ringing, in-progress, completed, busy, no-answer, failed, canceled
  transcript   Json?    // [{speaker, text, timestamp}]
  result       String?  // summary of the call outcome
  duration     Int?     // seconds
  recordingUrl String?
  channel      String   // whatsapp, telegram, web
  briefing     Json?    // Call briefing document (callerIdentity, targetName, keyMessages, tone, etc.)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([callSid])
  @@index([status])
  @@map("voice_calls")
}

