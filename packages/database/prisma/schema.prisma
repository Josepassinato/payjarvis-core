generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_KYC
}

enum KycLevel {
  NONE
  BASIC
  VERIFIED
  ENHANCED
}

enum BotStatus {
  ACTIVE
  PAUSED
  REVOKED
}

enum AgentStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

enum BotPlatform {
  TELEGRAM
  DISCORD
  WHATSAPP
  SLACK
  CUSTOM_API
}

enum BditTokenStatus {
  ISSUED
  USED
  EXPIRED
  REVOKED
}

enum TransactionDecision {
  APPROVED
  BLOCKED
  PENDING_HUMAN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum HandoffObstacle {
  CAPTCHA
  AUTH
  NAVIGATION
  OTHER
}

enum HandoffStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  EXPIRED
  CANCELLED
}

enum MerchantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum MerchantStatus {
  ACTIVE
  SUSPENDED
  PENDING_REVIEW
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  BNPL
  SKYFIRE
  AMAZON
  PIX
  CREDIT_CARD
}

enum PaymentMethodStatus {
  CONNECTED
  PENDING
  DISABLED
  EXPIRED
}

// ─── Models ───

model User {
  id                  String     @id @default(cuid())
  clerkId             String     @unique
  email               String     @unique
  fullName            String
  phone               String?    @unique
  dateOfBirth         DateTime?
  documentNumber      String?
  country             String?
  address             Json?
  kycLevel            KycLevel   @default(NONE)
  kycPhotoPath        String?
  kycSubmittedAt      DateTime?
  status              UserStatus @default(PENDING_KYC)
  onboardingStep      Int        @default(0)
  termsAcceptedAt     DateTime?
  telegramChatId      String?    @unique
  approvalThreshold   Float      @default(50.0)
  onboardingCompleted Boolean    @default(false)
  botActivatedAt      DateTime?
  notificationChannel String     @default("none") // "none" | "telegram" | "email"
  botNickname         String?    // custom name the user gave to the bot
  shippingAddress     String?    @map("shipping_address")
  stripeAccountId        String?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  subscriptionStatus     String?    // active | past_due | canceled | trialing
  subscriptionEndsAt     DateTime?
  planType               String     @default("free") // free | premium
  verifiedCallerId       String?    // user's verified phone for outbound caller ID
  callerIdDisclaimerAt   DateTime?  // when user accepted caller ID disclaimer
  callerIdVerifiedAt     DateTime?  // when caller ID was verified via Twilio
  latitude               Float?
  longitude              Float?
  locationUpdatedAt      DateTime?  @map("location_updated_at")
  createdAt              DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  bots               Bot[]
  agents             Agent[]
  transactions       Transaction[]
  approvalRequests   ApprovalRequest[]
  handoffRequests    HandoffRequest[]
  telegramLinkCode   TelegramLinkCode?
  paymentMethods     PaymentMethod[]
  instanceAssignment InstanceUser?
  storeContexts      StoreContext[]
  shareLinks         BotShareLink[]
  botClones          BotClone[]        // bots que este user clonou
  llmCredits         LlmCredit?        @relation("UserCredits")
  zkVault            UserZkVault?
  secureItems        SecureItem[]

  @@map("users")
}

model TelegramLinkCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_link_codes")
}

model PaymentMethod {
  id              String              @id @default(cuid())
  userId          String
  provider        PaymentProvider
  status          PaymentMethodStatus @default(PENDING)
  accountId       String?             // e.g. Stripe account ID, PayPal email
  displayName     String?             // "PayPal (jose@gmail.com)", "Visa ••••4242"
  credentials     Json?               // encrypted provider-specific data
  isDefault       Boolean             @default(false)
  metadata        Json?               // display info, last4, brand, balance, etc
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, accountId])
  @@index([userId])
  @@map("payment_methods")
}

// ─── Agent Identity (first-class) ───

model Agent {
  id                String      @id        // ag_xxxxx — set at application level
  botId             String      @unique
  ownerId           String
  name              String
  description       String      @default("")
  status            AgentStatus @default(ACTIVE)
  kycLevel          KycLevel    @default(NONE)
  trustScore        Int         @default(500) // 0-1000 scale
  totalSpent        Float       @default(0)
  transactionsCount Int         @default(0)
  lastActivityAt    DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  bot        Bot              @relation(fields: [botId], references: [id], onDelete: Cascade)
  owner      User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reputation AgentReputation?

  @@index([ownerId])
  @@index([botId])
  @@map("agents")
}

// ─── Bot (legacy wrapper, backward compatible) ───

model Bot {
  id             String      @id @default(cuid())
  ownerId        String
  name           String
  platform       BotPlatform
  apiKeyHash     String
  status         BotStatus   @default(ACTIVE)
  trustScore     Float       @default(50)  // 0-100 legacy scale
  totalApproved  Int         @default(0)
  totalBlocked   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  systemPrompt   String?   @map("system_prompt")
  botDisplayName String?   @map("bot_display_name")
  capabilities   String[]  @default([])
  language       String    @default("en-US")

  owner            User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  agent            Agent?
  policy           Policy?
  bditTokens       BditToken[]
  transactions     Transaction[]
  approvalRequests ApprovalRequest[]
  handoffRequests  HandoffRequest[]
  integrations     BotIntegration[]
  storePermissions StoreBotPermission[]
  shareLinks       BotShareLink[]
  clones           BotClone[]        // bots clonados a partir deste

  @@index([ownerId])
  @@map("bots")
}

model Policy {
  id                 String   @id @default(cuid())
  botId              String   @unique
  maxPerTransaction  Float    @default(100)
  maxPerDay          Float    @default(500)
  maxPerWeek         Float    @default(2000)
  maxPerMonth        Float    @default(5000)
  autoApproveLimit   Float    @default(50)
  requireApprovalUp  Float    @default(200)
  allowedDays        Int[]    @default([1, 2, 3, 4, 5]) // 0=Sun, 6=Sat
  allowedHoursStart  Int      @default(8)
  allowedHoursEnd    Int      @default(22)
  timezone           String   @default("America/New_York")
  allowedCategories  String[] @default([])
  blockedCategories  String[] @default([])
  merchantWhitelist  String[] @default([])
  merchantBlacklist  String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("policies")
}

model BditToken {
  id         String          @id @default(cuid())
  jti        String          @unique
  tokenValue String?
  botId      String
  agentId    String?         // agent identity reference
  merchantId String?
  amount     Float
  category   String
  status     BditTokenStatus @default(ISSUED)
  issuedAt   DateTime        @default(now())
  expiresAt  DateTime
  usedAt     DateTime?

  bot      Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@index([botId])
  @@index([agentId])
  @@index([jti])
  @@map("bdit_tokens")
}

model Transaction {
  id               String              @id @default(cuid())
  botId            String
  agentId          String?             // agent identity reference
  ownerId          String
  merchantId       String?
  merchantName     String
  bdtJti           String?
  amount           Float
  currency         String              @default("BRL")
  category         String
  decision         TransactionDecision
  decisionReason   String
  approvalId       String?
  approvedByHuman  Boolean             @default(false)
  stripePaymentId  String?
  createdAt        DateTime            @default(now())

  bot   Bot  @relation(fields: [botId], references: [id], onDelete: Cascade)
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  approvalRequest ApprovalRequest?

  @@index([botId])
  @@index([agentId])
  @@index([ownerId])
  @@index([createdAt])
  @@map("transactions")
}

model ApprovalRequest {
  id            String         @id @default(cuid())
  transactionId String         @unique
  botId         String
  agentId       String?        // agent identity reference
  ownerId       String
  amount        Float
  merchantName  String
  category      String
  status        ApprovalStatus @default(PENDING)
  expiresAt     DateTime
  respondedAt   DateTime?
  pushSent      Boolean        @default(false)
  createdAt     DateTime       @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  bot         Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, status])
  @@map("approval_requests")
}

model HandoffRequest {
  id           String          @id @default(cuid())
  botId        String
  ownerId      String
  sessionUrl   String
  obstacleType HandoffObstacle
  description  String
  metadata     Json?
  status       HandoffStatus   @default(PENDING)
  expiresAt    DateTime
  resolvedAt   DateTime?
  resolvedNote String?
  pushSent     Boolean         @default(false)
  createdAt    DateTime        @default(now())

  bot   Bot  @relation(fields: [botId], references: [id], onDelete: Cascade)
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([botId, status])
  @@index([ownerId, status])
  @@map("handoff_requests")
}

model Merchant {
  id            String         @id @default(cuid())
  merchantKey   String         @unique
  apiKeyHash    String
  name          String
  website       String?
  plan          MerchantPlan   @default(FREE)
  webhookUrl    String?
  minTrustScore Float          @default(50)
  status        MerchantStatus @default(PENDING_REVIEW)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  bditTokens BditToken[]

  @@map("merchants")
}

// ─── Agent Reputation ───

model AgentReputation {
  id                    String   @id @default(cuid())
  agentId               String   @unique
  successfulTransactions Int     @default(0)
  blockedTransactions   Int      @default(0)
  failedTransactions    Int      @default(0)
  chargebacks           Int      @default(0)
  anomalyEvents         Int      @default(0)
  merchantCount         Int      @default(0)
  merchants             String[] @default([])
  totalSpent            Float    @default(0)
  averageTransaction    Float    @default(0)
  lastTransactionAt     DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("agent_reputations")
}

// ─── Platform Registration ───

model PlatformRegistration {
  id           String   @id @default(cuid())
  platformType String                         // e.g. "shopify", "woocommerce", "custom"
  webhookUrl   String
  events       String[] @default([])          // subscribed event types
  secret       String                         // HMAC secret for webhook signing
  contactEmail String?
  isActive     Boolean  @default(false)       // activated after verification ping
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([platformType])
  @@index([isActive])
  @@map("platform_registrations")
}

// ─── Bot Integrations (third-party providers) ───

model BotIntegration {
  id          String    @id @default(cuid())
  botId       String
  provider    String    // e.g. "amadeus", "opentable", "uber_eats", "ticketmaster"
  category    String    // e.g. "travel", "restaurants", "events", "marketplace"
  enabled     Boolean   @default(false)
  connectedAt DateTime?
  config      Json?     // provider-specific config (tokens, preferences)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, provider])
  @@index([botId])
  @@map("bot_integrations")
}

// ─── Audit Log ───

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorType  String   // "user" | "bot" | "agent" | "system"
  actorId    String
  payload    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Append-only: no UPDATE or DELETE operations allowed at application level
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Policy Decision Log ───

model PolicyDecisionLog {
  id         String   @id @default(cuid())
  botId      String
  action     Json     // { type, provider, amount, category, merchantId }
  allowed    Boolean
  reason     String
  trustLevel String   // RESTRICTED|STANDARD|TRUSTED|AUTONOMOUS
  layer      Int      @default(1) // 1=core, 2=api, 3=composio, 4=browserbase
  createdAt  DateTime @default(now())

  @@index([botId])
  @@index([createdAt])
  @@map("policy_decision_logs")
}

// ─── OpenClaw Instance Management ───

model OpenClawInstance {
  id          String   @id @default(cuid())
  name        String   // "instance-01", "instance-02"
  processName String   // nome no PM2
  port        Int      @unique
  capacity    Int      @default(100)
  currentLoad Int      @default(0)
  status      String   @default("ACTIVE") // ACTIVE|FULL|OFFLINE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users InstanceUser[]

  @@index([status])
  @@map("openclaw_instances")
}

model InstanceUser {
  id         String   @id @default(cuid())
  userId     String   @unique // usuario so pode estar em 1 instancia
  instanceId String
  assignedAt DateTime @default(now())

  instance OpenClawInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@map("instance_users")
}

// ─── Commerce Search Log ───

model CommerceSearchLog {
  id          String   @id @default(cuid())
  botId       String
  service     String   // flights, hotels, restaurants, events, transport, delivery
  params      Json
  resultCount Int
  cached      Boolean  @default(false)
  durationMs  Int
  createdAt   DateTime @default(now())

  @@index([botId])
  @@index([service])
  @@index([createdAt])
  @@map("commerce_search_logs")
}

// ─── Legacy: User Account Vault (to be migrated to StoreContext) ───

model UserAccountVault {
  id           String    @id @default(cuid())
  userId       String
  provider     String    // "amazon", "uber", "hotels", etc.
  cookiesEnc   String    // JSON de cookies, criptografado AES-256
  userAgent    String    // user agent da sessão original
  isValid      Boolean   @default(true)
  lastVerified DateTime  @default(now())
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider, isValid])
  @@map("user_account_vaults")
}

// ─── Legacy: Amazon Order Tracking (to be migrated to universal orders) ───

model AmazonOrder {
  id            String   @id @default(cuid())
  botId         String
  userId        String
  asin          String
  title         String
  price         Float
  quantity      Int      @default(1)
  status        String   @default("PENDING")
  amazonOrderId String?
  errorMsg      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([botId])
  @@index([status])
  @@map("amazon_orders")
}

// ─── Connected Stores ───

model StoreContext {
  id              String    @id @default(cuid())
  userId          String
  store           String    // e.g. "amazon", "walmart", "target"
  storeUrl        String    // e.g. "https://www.amazon.com"
  storeLabel      String    // e.g. "Amazon"
  bbContextId     String?   // Browserbase Context ID — only used for scraping, not login
  status          String    @default("configured") // configured | authenticated | expired
  pendingProduct  Json?     // { asin, name, price, url } — saved before login, recovered after
  authenticatedAt DateTime?
  lastUsedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions       StoreSession[]
  botPermissions StoreBotPermission[]

  @@unique([userId, store])
  @@index([userId])
  @@index([store, status])
  @@map("store_contexts")
}

model StoreSession {
  id             String    @id @default(cuid())
  storeContextId String
  bbSessionId    String    // Browserbase session ID
  status         String    @default("running") // running | completed | expired
  purpose        String?   // e.g. "login", "purchase", "search"
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  storeContext StoreContext @relation(fields: [storeContextId], references: [id], onDelete: Cascade)

  @@index([storeContextId])
  @@index([status])
  @@map("store_sessions")
}

model StoreBotPermission {
  id                String   @id @default(cuid())
  botId             String
  storeContextId    String
  enabled           Boolean  @default(true)
  maxPerTransaction Float    @default(50)
  maxPerDay         Float    @default(150)
  maxPerMonth       Float    @default(500)
  allowedCategories String[] @default([])
  autoApproveBelow  Float    @default(25)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bot          Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)
  storeContext StoreContext @relation(fields: [storeContextId], references: [id], onDelete: Cascade)

  @@unique([botId, storeContextId])
  @@index([botId])
  @@index([storeContextId])
  @@map("store_bot_permissions")
}

// ─── Bot Onboarding Session (Conversational) ───

model OnboardingSession {
  id                 String    @id @default(cuid())
  telegramChatId     String?   @unique
  whatsappPhone      String?   @unique
  shareCode          String?
  step               String    @default("start") // name | bot_nickname | email_password | email_confirm | beta_choice | limits | stores | payment | complete
  fullName           String?
  botNickname        String?
  email              String?
  password           String?   // temporary: cleared after user creation
  emailToken         String?
  emailAttempts      Int       @default(0)
  userId             String?
  botId              String?
  limitsSet          Boolean   @default(false)
  storesConfigured   Boolean   @default(false)
  language           String    @default("en")
  paymentSetup       Boolean   @default(false)
  stripeSetupIntent  String?
  stripePaymentLink  String?
  expiresAt          DateTime
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([shareCode])
  @@index([userId])
  @@map("onboarding_sessions")
}

// ─── LLM Credits ───

model LlmCredit {
  id                String    @id @default(cuid())
  userId            String    @unique
  messagesTotal     Int       @default(5000)
  messagesUsed      Int       @default(0)
  messagesRemaining Int       @default(5000)
  freeTrialEndsAt   DateTime?
  freeTrialActive   Boolean   @default(false)
  alert75Sent       Boolean   @default(false)
  alert90Sent       Boolean   @default(false)
  alert100Sent      Boolean   @default(false)
  alertDay55Sent    Boolean   @default(false)
  alertDay58Sent    Boolean   @default(false)
  alertDay60Sent    Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation("UserCredits", fields: [userId], references: [id], onDelete: Cascade)

  @@index([freeTrialEndsAt])
  @@map("llm_credits")
}

model LlmUsageLog {
  id              String   @id @default(cuid())
  userId          String
  platform        String
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  costReal        Float
  costCharged     Float
  messagesCharged Int      @default(1)
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("llm_usage_logs")
}

model CreditPurchase {
  id              String   @id @default(cuid())
  userId          String
  packageId       String
  messagesAdded   Int
  amountUsd       Float
  stripePaymentId String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@map("credit_purchases")
}

// ─── Onboarding Sequence (drip banners) ───

model OnboardingSequence {
  id             String    @id @default(cuid())
  userId         String    @unique
  platform       String
  chatId         String
  joinedAt       DateTime  @default(now())
  lastActiveAt   DateTime  @default(now())
  currentStep    Int       @default(0)
  nextSendAt     DateTime?
  stepsCompleted Int[]     @default([])
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([nextSendAt])
  @@index([active])
  @@map("onboarding_sequences")
}

// ─── Bot Share (Viral Growth) ───

model BotShareLink {
  id              String    @id @default(cuid())
  code            String    @unique
  botId           String
  createdByUserId String
  templateConfig  Json
  expiresAt       DateTime?
  maxUses         Int?
  useCount        Int       @default(0)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bot       Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)
  createdBy User       @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  clones    BotClone[]

  @@index([code])
  @@index([createdByUserId])
  @@index([botId])
  @@map("bot_share_links")
}

model BotClone {
  id               String   @id @default(cuid())
  shareCode        String
  newBotId         String
  newUserId        String
  referredByUserId String
  clonedAt         DateTime @default(now())

  shareLink BotShareLink @relation(fields: [shareCode], references: [code], onDelete: Cascade)
  newBot    Bot          @relation(fields: [newBotId], references: [id], onDelete: Cascade)
  newUser   User         @relation(fields: [newUserId], references: [id], onDelete: Cascade)

  @@index([shareCode])
  @@index([newUserId])
  @@index([referredByUserId])
  @@map("bot_clones")
}

// ─── Admin Dashboard ───

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("admin")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions AdminSession[]

  @@map("admin_users")
}

model AdminSession {
  id        String   @id @default(cuid())
  adminId   String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("admin_sessions")
}

model Broadcast {
  id              String    @id @default(cuid())
  title           String
  message         String
  imageUrl        String?
  audience        String    @default("all")
  status          String    @default("draft")
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int       @default(0)
  delivered       Int       @default(0)
  failed          Int       @default(0)
  replied         Int       @default(0)
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  logs BroadcastLog[]

  @@index([status])
  @@index([scheduledAt])
  @@map("broadcasts")
}

model BroadcastLog {
  id          String   @id @default(cuid())
  broadcastId String
  userId      String
  platform    String
  chatId      String
  status      String
  sentAt      DateTime @default(now())

