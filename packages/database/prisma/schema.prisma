// ─── Sentinel — DevOps Agent ───

model SentinelLog {
  id        String   @id @default(cuid())
  type      String   // service_check | infra_check | fraud_check | action_taken
  service   String?
  status    String   // ok | warning | error | fixed
  message   String
  details   Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("sentinel_logs")
}

model SentinelIncident {
  id          String    @id @default(cuid())
  title       String
  description String
  severity    String    // low | medium | high | critical
  status      String    @default("open") // open | investigating | resolved | ignored
  service     String?
  userId      String?
  autoFixed   Boolean   @default(false)
  fixDetails  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("sentinel_incidents")
}

model FraudAlert {
  id            String    @id @default(cuid())
